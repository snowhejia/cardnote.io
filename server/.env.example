# 复制为同目录下的 .env 后修改。勿把含密码的 .env 提交到 Git。

# ─── 数据库（必填）────────────────────────────────────────────
# 本地 Docker（server 目录执行 docker compose up -d 后）：
DATABASE_URL=postgresql://mikujar:mikujar_local_test@127.0.0.1:5433/mikujar
# 本机无 SSL 时务必关闭（Docker / 本地 pg 常用）
PG_SSL=false

# 云端 PostgreSQL（腾讯云等）示例：一般可删掉 PG_SSL 行，由客户端使用 sslmode
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# 首次建表（容器已启动、在 server 目录执行）：
#   docker compose exec -T postgres psql -U mikujar -d mikujar -v ON_ERROR_STOP=1 < scripts/schema.sql

# ─── 服务 ────────────────────────────────────────────────────
PORT=8787

# 启用登录门闩 + 首个管理员（生产必配）
# JWT_SECRET=至少32字节的随机串
# ADMIN_PASSWORD=首次启动时在空库创建管理员的密码

# 可选：静态 API Token（旧版脚本）
# API_TOKEN=
